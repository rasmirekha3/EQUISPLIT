<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Expense Splitter Pro</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; margin: 0; padding: 20px;
        }

        .card {
            background: white; border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%; max-width: 500px; padding: 25px;
            display: none; /* Hidden by default */
        }

        .active { display: block; }

        h2 { margin-top: 0; color: #1a1a1a; font-size: 1.4rem; }

        .form-group { margin-bottom: 18px; }
        label { display: block; font-weight: 600; margin-bottom: 8px; color: #4a5568; }

        input, select {
            width: 100%; padding: 12px; border: 1px solid #e2e8f0;
            border-radius: 8px; box-sizing: border-box; font-size: 1rem;
        }

        /* Icons */
        .icon-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 15px; }
        .icon-box { 
            width: 40px; height: 40px; background: #f1f5f9; 
            display: flex; justify-content: center; align-items: center;
            border-radius: 8px; cursor: pointer; border: 2px solid transparent;
        }
        .icon-box.selected { border-color: #7c3aed; background: #ede9fe; }

        /* Members */
        .member-row { display: flex; gap: 8px; margin-bottom: 8px; }
        .btn-add { background: #f1f5f9; border: 1px solid #cbd5e0; padding: 5px 15px; border-radius: 6px; cursor: pointer; }

        /* Split Grid */
        .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .split-item { background: #f8fafc; padding: 10px; border-radius: 8px; display: flex; align-items: center; gap: 8px; }
        .split-item input { width: auto; }

        /* Buttons */
        .footer-btns { display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px; }
        .btn { padding: 12px 25px; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; }
        .btn-gray { background: #f1f5f9; color: #4a5568; }
        .btn-purple { background: #7c3aed; color: white; }
        .btn-purple:disabled { background: #cbd5e0; }

        /* Table Style */
        .table-container { width: 100%; overflow-x: auto; margin-top: 20px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #e2e8f0; padding: 12px; text-align: left; }
        th { background: #f8fafc; }

        .confirm-text { line-height: 1.8; color: #4a5568; }
        .highlight { color: #7c3aed; font-weight: bold; }
    </style>
</head>
<body>

    <div id="step-1" class="card active">
        <h2>Create New Group</h2>
        <div class="form-group">
            <label>Group Icon</label>
            <div class="icon-grid" id="icon-picker">
                <div class="icon-box selected">👥</div>
                <div class="icon-box">✈️</div>
                <div class="icon-box">🏠</div>
                <div class="icon-box">🎉</div>
                <div class="icon-box">🍕</div>
                <div class="icon-box">💼</div>
            </div>
        </div>
        <div class="form-group">
            <label>Group Name</label>
            <input type="text" id="group-name" placeholder="e.g. Hackathon Project">
        </div>
        <div class="form-group">
            <label>Members (Min 2)</label>
            <div id="member-inputs">
                <div class="member-row"><input type="text" class="m-name" placeholder="Member name"></div>
                <div class="member-row"><input type="text" class="m-name" placeholder="Member name"></div>
            </div>
            <button class="btn-add" onclick="addMemberField()">+ Add Member</button>
        </div>
        <div class="footer-btns">
            <button class="btn btn-gray">Cancel</button>
            <button class="btn btn-purple" onclick="goToStep2()">Create Group</button>
        </div>
    </div>

    <div id="step-2" class="card">
        <h2>Add Expense</h2>
        <div class="form-group">
            <label>Group</label>
            <input type="text" id="display-group-name" readonly>
        </div>
        <div style="display:flex; gap:15px">
            <div class="form-group" style="flex:1">
                <label>Amount (₹)</label>
                <input type="number" id="exp-amount" placeholder="0.00">
            </div>
            <div class="form-group" style="flex:1">
                <label>Date</label>
                <input type="date" id="exp-date">
            </div>
        </div>
        <div class="form-group">
            <label>Paid By</label>
            <select id="paid-by-select"></select>
        </div>
        <div class="form-group">
            <label>Split Between</label>
            <div class="split-grid" id="split-checkboxes"></div>
        </div>
        <div class="form-group">
            <label>Note (Optional)</label>
            <input type="text" id="exp-note" placeholder="e.g. Lunch">
        </div>
        <div class="footer-btns">
            <button class="btn btn-gray" onclick="showStep(1)">Back</button>
            <button class="btn btn-purple" onclick="goToStep3()">Next</button>
        </div>
    </div>

    <div id="step-3" class="card">
        <h2>Confirm Expense</h2>
        <div class="confirm-text" id="confirm-details">
            </div>
        <div class="footer-btns">
            <button class="btn btn-gray" onclick="showStep(2)">Go Back</button>
            <button class="btn btn-purple" onclick="saveAndShowTable()">Confirm & Save</button>
        </div>
    </div>

    <div id="step-4" class="card" style="max-width: 800px;">
        <h2>Expense Summary</h2>
        <div class="table-container">
            <table id="expense-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Group</th>
                        <th>Payer</th>
                        <th>Amount</th>
                        <th>Split With</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <div class="footer-btns">
            <button class="btn btn-gray" onclick="location.reload()">Add New</button>
            <button class="btn btn-purple" onclick="downloadCSV()">Download CSV</button>
        </div>
    </div>

    <script>
        let groupData = { name: '', members: [], icon: '👥' };
        let currentExpense = {};

        // Helper: Show specific card
        function showStep(stepNum) {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
            document.getElementById(`step-${stepNum}`).classList.add('active');
        }

        // Step 1 Logic
        function addMemberField() {
            const container = document.getElementById('member-inputs');
            const div = document.createElement('div');
            div.className = 'member-row';
            div.innerHTML = '<input type="text" class="m-name" placeholder="Member name">';
            container.appendChild(div);
        }

        function goToStep2() {
            groupData.name = document.getElementById('group-name').value;
            const names = document.querySelectorAll('.m-name');
            groupData.members = Array.from(names).map(n => n.value).filter(v => v !== '');

            if(!groupData.name || groupData.members.length < 2) {
                alert("Please enter group name and at least 2 members!");
                return;
            }

            // Populate Step 2
            document.getElementById('display-group-name').value = groupData.name;
            document.getElementById('exp-date').valueAsDate = new Date();
            
            const paidBy = document.getElementById('paid-by-select');
            const splitBy = document.getElementById('split-checkboxes');
            paidBy.innerHTML = ''; splitBy.innerHTML = '';

            groupData.members.forEach(m => {
                paidBy.innerHTML += `<option value="${m}">${m}</option>`;
                splitBy.innerHTML += `
                    <div class="split-item">
                        <input type="checkbox" value="${m}" checked> <span>${m}</span>
                    </div>`;
            });

            showStep(2);
        }

        // Step 2 Logic
        function goToStep3() {
            const amount = document.getElementById('exp-amount').value;
            const payer = document.getElementById('paid-by-select').value;
            const date = document.getElementById('exp-date').value;
            const splitWith = Array.from(document.querySelectorAll('#split-checkboxes input:checked')).map(c => c.value);
            const note = document.getElementById('exp-note').value || 'No note';

            if(!amount || splitWith.length === 0) {
                alert("Enter amount and select at least one person to split!");
                return;
            }

            currentExpense = { amount, payer, date, splitWith, note };

            document.getElementById('confirm-details').innerHTML = `
                <p><strong>${payer}</strong> paid <span class="highlight">₹${parseFloat(amount).toFixed(2)}</span></p>
                <p>Split between: ${splitWith.join(', ')}</p>
                <p>Date: ${date}</p>
                <p>Note: ${note}</p>
            `;
            showStep(3);
        }

        // Step 3 & 4 Logic
        function saveAndShowTable() {
            const tbody = document.querySelector('#expense-table tbody');
            const row = tbody.insertRow();
            row.innerHTML = `
                <td>${currentExpense.date}</td>
                <td>${groupData.name}</td>
                <td>${currentExpense.payer}</td>
                <td>₹${currentExpense.amount}</td>
                <td>${currentExpense.splitWith.join(', ')}</td>
                <td>${currentExpense.note}</td>
            `;
            showStep(4);
        }

        function downloadCSV() {
            let csv = "Date,Group,Payer,Amount,Split With,Note\n";
            const rows = document.querySelectorAll("#expense-table tbody tr");
            
            rows.forEach(row => {
                const cols = row.querySelectorAll("td");
                let rowData = Array.from(cols).map(c => `"${c.innerText}"`).join(",");
                csv += rowData + "\n";
            });

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('hidden', '');
            a.setAttribute('href', url);
            a.setAttribute('download', 'expenses.csv');
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        // Icon Selection UI
        document.getElementById('icon-picker').addEventListener('click', (e) => {
            if(e.target.classList.contains('icon-box')) {
                document.querySelectorAll('.icon-box').forEach(b => b.classList.remove('selected'));
                e.target.classList.add('selected');
                groupData.icon = e.target.innerText;
            }
        });
    </script>
</body>
</html>
