<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>DebtSimplify Dashboard</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
display:flex;
background:#f5f6fb;
}

/* SIDEBAR */

.sidebar{
width:230px;
height:100vh;
background:white;
border-right:1px solid #eee;
padding:20px;
}

.logo{
font-size:20px;
font-weight:bold;
margin-bottom:40px;
color:#6a5cff;
}

.menu{
list-style:none;
}

.menu li{
padding:12px;
margin-bottom:10px;
border-radius:8px;
cursor:pointer;
}

.menu li:hover{
background:#f0edff;
}

.active{
background:#edeaff;
color:#6a5cff;
}

/* MAIN */

.main{
flex:1;
padding:30px;
overflow-y:auto;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.add-btn{
background:#6a5cff;
color:white;
padding:10px 18px;
border:none;
border-radius:8px;
cursor:pointer;
}

/* CARDS */

.cards{
display:flex;
gap:20px;
margin-bottom:30px;
}

.card{
background:white;
padding:20px;
flex:1;
border-radius:12px;
box-shadow:0 3px 10px rgba(0,0,0,0.05);
}

.card h4{
color:#777;
margin-bottom:10px;
}

.card h2{
font-size:26px;
}

/* GROUPS */

.groups{
background:white;
padding:20px;
border-radius:12px;
margin-bottom:30px;
}

.group-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
margin-top:15px;
}

.group{
background:#f7f8fc;
padding:15px;
border-radius:10px;
}

/* TRANSACTIONS */

.transactions{
background:white;
padding:20px;
border-radius:12px;
}

.transaction{
display:flex;
justify-content:space-between;
padding:15px 0;
border-bottom:1px solid #eee;
}

.transaction:last-child{
border-bottom:none;
}

.tr-left{
display:flex;
gap:10px;
}

.icon{
width:40px;
height:40px;
background:#26c281;
color:white;
display:flex;
align-items:center;
justify-content:center;
border-radius:10px;
font-weight:bold;
}

.tr-info small{
color:#777;
}

.amount{
font-weight:bold;
}

.date{
font-size:12px;
color:#999;
}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<div class="logo">DebtSimplify</div>

<ul class="menu">
<li class="active">Dashboard</li>
<li>Groups</li>
<li>Expenses</li>
<li>Settlements</li>
</ul>

</div>


<!-- MAIN -->

<div class="main">

<div class="header">
<h2>Smart Debt Simplifier</h2>
<button class="add-btn">+ Add Expense</button>
</div>


<!-- CARDS -->

<div class="cards">

<div class="card">
<h4>Total Expenses</h4>
<h2>₹40045600.00</h2>
</div>

<div class="card">
<h4>Groups</h4>
<h2>7</h2>
<p>7 active groups</p>
</div>

<div class="card">
<h4>Pending Balance</h4>
<h2>₹40038808.33</h2>
<p>Total unsettled</p>
</div>

</div>


<!-- GROUPS -->

<div class="groups">

<h3>Your Groups</h3>

<div class="group-grid">

<div class="group">bbsr<br><small>4 members</small></div>
<div class="group">IIIT Trip<br><small>4 members</small></div>
<div class="group">LAPTOP BUY<br><small>2 members</small></div>

<div class="group">birthday party<br><small>4 members</small></div>
<div class="group">Goa Trip 2025<br><small>4 members</small></div>
<div class="group">Roommates<br><small>3 members</small></div>

</div>

</div>


<!-- TRANSACTIONS -->

<div class="transactions">

<h3>Recent Transactions</h3>

<div id="transactionList"></div>

</div>

</div>


<script>

const transactions = [

{title:"Expense", info:"b paid · bbsr", amount:"₹40000000.00", date:"Mar 14, 2026"},
{title:"Expense", info:"rasmi paid · IIIT Trip", amount:"₹500.00", date:"Mar 14, 2026"},
{title:"Expense", info:"happy paid · IIIT Trip", amount:"₹500.00", date:"Mar 14, 2026"},
{title:"Expense", info:"happy paid · IIIT Trip", amount:"₹500.00", date:"Mar 14, 2026"},
{title:"Expense", info:"happy paid · LAPTOP BUY", amount:"₹30000.00", date:"Mar 14, 2026"},
{title:"Expense", info:"girish paid · birthday party", amount:"₹2000.00", date:"Mar 13, 2026"},
{title:"Hotel booking for Goa", info:"Rahul paid · Goa Trip 2025", amount:"₹2400.00", date:"Dec 15, 2025"},
{title:"Dinner at beach shack", info:"Sara paid · Goa Trip 2025", amount:"₹1200.00", date:"Dec 16, 2025"},
{title:"Scuba diving tickets", info:"Aman paid · Goa Trip 2025", amount:"₹800.00", date:"Dec 17, 2025"}

];

const list = document.getElementById("transactionList");

transactions.forEach(t => {

list.innerHTML += `

<div class="transaction">

<div class="tr-left">

<div class="icon">$</div>

<div class="tr-info">
<b>${t.title}</b><br>
<small>${t.info}</small>
</div>

</div>

<div>

<div class="amount">${t.amount}</div>
<div class="date">${t.date}</div>

</div>

</div>

`;

});

</script>

</body>
</html>
